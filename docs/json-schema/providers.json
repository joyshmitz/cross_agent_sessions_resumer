{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casr.dev/schema/providers.json",
  "title": "casr providers --json",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schema_version",
      "name",
      "slug",
      "alias",
      "installed",
      "version",
      "evidence"
    ],
    "properties": {
      "schema_version": {"type": "integer", "const": 1},
      "name": {"type": "string"},
      "slug": {"type": "string"},
      "alias": {"type": "string"},
      "installed": {"type": "boolean"},
      "version": {"type": ["string", "null"]},
      "evidence": {
        "type": "array",
        "items": {"type": "string"}
      }
    }
  }
}
